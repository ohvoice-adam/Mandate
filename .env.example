# ── Docker deployment ────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values before running docker-compose up.

# Domain for this campaign instance (used by Caddy for TLS and routing)
CAMPAIGN1_DOMAIN=petition.example.com

POSTGRES_PASSWORD=change-me-strong-password
SECRET_KEY=change-me-run-python3-c-import-secrets-print-secrets.token_hex-32

# ── Default admin user ────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@example.com
# Default password is "changeme" — the admin is forced to change it on first login.
# Set this to override the default.
ADMIN_PASSWORD=

# ── Multi-campaign ────────────────────────────────────────────────────────────
# To route a second campaign through this Caddy instance, uncomment and set:
# CAMPAIGN2_DOMAIN=campaign2.example.com
# Then uncomment the matching block in Caddyfile and reload Caddy.

# ── Local development (non-Docker) ───────────────────────────────────────────
# Uncomment and set these when running outside Docker.

#DATABASE_URL=postgresql://user:password@localhost:5432/mandate
#FLASK_ENV=development
#FLASK_DEBUG=1
#UPLOAD_FOLDER=/tmp/petition-qc-uploads
