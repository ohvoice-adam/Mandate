# ── Docker deployment ────────────────────────────────────────────────────────
# These three variables are all that docker-compose needs.
# Copy this file to .env and fill in the values before running docker-compose up.

DOMAIN=petition.example.com
POSTGRES_PASSWORD=change-me-strong-password
SECRET_KEY=change-me-run-python3-c-import-secrets-print-secrets.token_hex-32

# ── Default admin user ────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@example.com
# Default password is "changeme" — the admin is forced to change it on first login.
# Set this to override the default.
ADMIN_PASSWORD=

# ── Local development (non-Docker) ───────────────────────────────────────────
# Uncomment and set these when running outside Docker.

#DATABASE_URL=postgresql://user:password@localhost:5432/mandate
#FLASK_ENV=development
#FLASK_DEBUG=1
#UPLOAD_FOLDER=/tmp/petition-qc-uploads

# --- Added by starter kit ---
NODE_ENV=development
PORT=3000
STRICTDB_URI=YOUR_DATABASE_CONNECTION_STRING_HERE
JWT_SECRET=YOUR_JWT_SECRET_HERE
GITHUB_USERNAME=YOUR_GITHUB_USERNAME_HERE
NEXT_PUBLIC_RYBBIT_SITE_ID=YOUR_RYBBIT_SITE_ID_HERE
NEXT_PUBLIC_RYBBIT_URL=https://app.rybbit.io
DOCKER_HUB_USER=YOUR_DOCKER_HUB_USERNAME_HERE
DOCKER_IMAGE_NAME=YOUR_DOCKER_HUB_USER/YOUR_PROJECT_NAME
VPS_IP=YOUR_VPS_IP_HERE
DOKPLOY_URL=YOUR_DOKPLOY_URL_HERE
DOKPLOY_API_KEY=YOUR_DOKPLOY_API_KEY_HERE
DOKPLOY_APP_ID=YOUR_DOKPLOY_APP_ID_HERE
DOKPLOY_REFRESH_TOKEN=YOUR_DOKPLOY_REFRESH_TOKEN_HERE
RULECATCH_API_KEY=YOUR_RULECATCH_API_KEY_HERE
RULECATCH_REGION=us
