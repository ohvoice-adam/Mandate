# Environment template for additional campaign instances.
# Copy to .env in each campaign directory and fill in the values.
#
# The container name must:
#   1. Be unique across all campaigns on this server
#   2. Match the name used in the Caddyfile site block (e.g. mandate_web_2)

CAMPAIGN_CONTAINER_NAME=mandate_web_2

# Unique secrets — NEVER reuse POSTGRES_PASSWORD or SECRET_KEY across campaigns
POSTGRES_PASSWORD=change-me-strong-password
SECRET_KEY=change-me-run-python3-c-import-secrets-print-secrets.token_hex-32

# Admin bootstrap — forced password change on first login
ADMIN_EMAIL=admin@campaign2.example.com
ADMIN_PASSWORD=
